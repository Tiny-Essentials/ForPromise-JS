{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "allowJs": true,
        "checkJs": true,
        "declaration": true,
        "declarationMap": false,
        "declarationDir": "./dist",
        "emitDeclarationOnly": false,
        "target": "ESNext",
        "strict": true,
        "module": "nodenext",
        "moduleResolution": "nodenext"
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}